{
  "CompanyName": "QCode",
  "ApplicationName": "Nombre de la aplicación",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Information",
        "System": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Query": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}",
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      },
      {
        "Name": "Debug"
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki.observability.svc.cluster.local:3100",
          "labels": [
            {
              "key": "app",
              "value": "Nombre de la aplicación"
            },
            {
              "key": "environment",
              "value": "production"
            }
          ],
          "propertiesAsLabels": [
            "Application",
            "Environment"
          ],
          "credentials": {
            "login": "",
            "password": ""
          },
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Information"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithExceptionDetails"
    ]
  },
  "AllowedHosts": "*",
  "Identity": {
    "SecretKey": "",
    "Issuer": "",
    "Audience": ""
  },
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "",
    "Audience": "",
    "ExpirationMinutes": "60",
    "RefreshTokenExpirationDays": "30"
  },
  "Authentication": {
    "AllowPublicUsers": false,
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "",
      "TimeoutSeconds": 30
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "",
      "TenantId": "",
      "TimeoutSeconds": 30
    }
  },
  "OpenApi": {
    "Document": {
      "Description": "Plantilla de desarrollo",
      "Title": "API backend-template",
      "Version": "v1.0.0"
    }
  },
  "ConnectionStrings": {
    "DB": ""
  },
  "ServiceBus": {
    "ConnectionStrings": "",
    "TopicEBilling": "",
    "SuscriptionEBilling": ""
  },
  "FrontUrl": "",
  "EmailService": {
    "FromEmail": "",
    "FromName": "",
    "HeaderImage": "",
    "TestEmailTo": ""
  },
  "Infobip": {
    "BasePath": "",
    "ApiKey": ""
  },
  "PermissionMiddleware": {
    "EnableAuditLogging": true,
    "IncludeRequestDetails": true,
    "PermissionTimeoutSeconds": 5,
    "EnablePerformanceMetrics": false,
    "ExcludedPaths": [
      "/health",
      "/metrics",
      "/swagger",
      "/scalar/v1"
    ]
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "AuthPermitLimit": 10,
    "AuthWindowSeconds": 60,
    "ExcludedPaths": [
      "/health",
      "/metrics",
      "/swagger",
      "/scalar/v1"
    ]
  },
  "Recaptcha": {
    "Enabled": true,
    "SecretKey": "",
    "SiteKey": "",
    "VerificationUrl": "https://www.google.com/recaptcha/api/siteverify",
    "MinimumScore": 0.5,
    "TimeoutSeconds": 5,
    "RequiredEndpoints": [
      "/auth/login",
      "/auth/register",
      "/auth/forgotPassword"
    ]
  },
  "PasswordReset": {
    "Enabled": true,
    "MinimumIntervalMinutes": 5,
    "IncrementalIntervalsSeconds": [0, 30, 60, 300, 1800, 3600]
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
    "AllowedHeaders": ["Content-Type", "Authorization", "X-Requested-With", "X-Correlation-ID"],
    "ExposedHeaders": ["X-Correlation-ID"],
    "AllowCredentials": true,
    "PreflightMaxAgeSeconds": 600
  },
  "MemoryCache": {
    "SizeLimit": 10000,
    "CompactionPercentage": 0.25,
    "ExpirationScanFrequencySeconds": 60
  },
  "Pagination": {
    "MaxPageSize": 100,
    "DefaultPageSize": 10,
    "MinPage": 1
  },
  "CircuitBreaker": {
    "FailureThreshold": 6,
    "BreakDurationSeconds": 30,
    "TimeoutSeconds": 5
  }
}
