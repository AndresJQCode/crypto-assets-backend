{
  "CompanyName": "QCode",
  "ApplicationName": "Nombre de la aplicación",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Information",
        "System": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.EntityFrameworkCore.Query": "Warning",
        "Infrastructure": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}",
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      },
      {
        "Name": "Debug"
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki.observability.svc.cluster.local:3100",
          "labels": [
            {
              "key": "app",
              "value": "Nombre de la aplicación"
            },
            {
              "key": "environment",
              "value": "production"
            }
          ],
          "propertiesAsLabels": [
            "Application",
            "Environment"
          ],
          "credentials": {
            "login": "",
            "password": ""
          },
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Information"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithExceptionDetails"
    ]
  },
  "AllowedHosts": "*",
  "Identity": {
    "SecretKey": "",
    "Issuer": "",
    "Audience": ""
  },
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "",
    "Audience": "",
    "ExpirationMinutes": "60",
    "RefreshTokenExpirationDays": "30"
  },
  "Authentication": {
    "AllowPublicUsers": false,
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "",
      "TimeoutSeconds": 30
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "",
      "TenantId": "",
      "TimeoutSeconds": 30
    }
  },
  "OpenApi": {
    "Document": {
      "Description": "Plantilla de desarrollo",
      "Title": "API backend-template",
      "Version": "v1.0.0"
    }
  },
  "ConnectionStrings": {
    "DB": ""
  },
  "ServiceBus": {
    "ConnectionStrings": "",
    "TopicEBilling": "",
    "SuscriptionEBilling": ""
  },
  "FrontUrl": "",
  "EmailService": {
    "Provider": "Infobip",
    "FromEmail": "noreply@lulocrm.com",
    "FromName": "Lulo CRM",
    "HeaderImage": "https://lulocrm.com/images/logo.png",
    "TestEmailTo": "test@lulocrm.com"
  },
  "Infobip": {
    "BasePath": "https://api.infobip.com",
    "ApiKey": "your-infobip-api-key-here"
  },
  "PermissionMiddleware": {
    "EnableAuditLogging": true,
    "IncludeRequestDetails": true,
    "PermissionTimeoutSeconds": 5,
    "EnablePerformanceMetrics": false,
    "ExcludedPaths": [
      "/health",
      "/metrics",
      "/swagger",
      "/scalar/v1"
    ]
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "AuthPermitLimit": 10,
    "AuthWindowSeconds": 60,
    "ExcludedPaths": [
      "/health",
      "/metrics",
      "/swagger",
      "/scalar/v1"
    ]
  },
  "Recaptcha": {
    "Enabled": true,
    "ProjectId": "",
    "SiteKey": "",
    "ExpectedAction": "submit",
    "MinimumScore": 0.5,
    "TimeoutSeconds": 5,
    "RequiredEndpoints": [
      "/auth/login",
      "/auth/register",
      "/auth/forgotPassword"
    ],
    "CredentialsJson": "",
    "PasswordReset": {
      "Enabled": true,
      "MinimumIntervalMinutes": 5,
      "IncrementalIntervalsSeconds": [
        0,
        30,
        60,
        300,
        1800,
        3600
      ]
    },
    "Cors": {
      "AllowedOrigins": [],
      "AllowedMethods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "PATCH",
        "OPTIONS"
      ],
      "AllowedHeaders": [
        "Content-Type",
        "Authorization",
        "X-Requested-With",
        "X-Correlation-ID"
      ],
      "ExposedHeaders": [
        "X-Correlation-ID"
      ],
      "AllowCredentials": true,
      "PreflightMaxAgeSeconds": 600
    },
    "MemoryCache": {
      "SizeLimit": 10000,
      "CompactionPercentage": 0.25,
      "ExpirationScanFrequencySeconds": 60
    },
    "Pagination": {
      "MaxPageSize": 100,
      "DefaultPageSize": 10,
      "MinPage": 1
    },
    "CircuitBreaker": {
      "FailureThreshold": 6,
      "BreakDurationSeconds": 30,
      "TimeoutSeconds": 5
    },
    "Connectors": {
      "Shopify": {
        "ClientId": "",
        "ClientSecret": "",
        "RedirectUri": "{{FrontUrl}}/connectors/callback/shopify",
        "Scopes": [
          "read_fulfillments",
          "write_fulfillments",
          "read_orders",
          "write_orders",
          "read_products",
          "write_products",
          "read_customers",
          "read_shipping",
          "read_third_party_fulfillment_orders",
          "write_third_party_fulfillment_orders",
          "read_assigned_fulfillment_orders",
          "write_assigned_fulfillment_orders",
          "read_merchant_managed_fulfillment_orders",
          "write_merchant_managed_fulfillment_orders",
          "read_inventory",
          "write_inventory",
          "read_locations"
        ],
        "ApiVersion": "2026-01",
        "TimeoutSeconds": 30
      },
      "Bybit": {
        "DefaultTestnet": false,
        "TimeoutSeconds": 30,
        "RateLimitPerSecond": 10
      }
    },
    "PubSub": {
      "Enabled": false,
      "ProjectId": "",
      "SubscriptionId": "",
      "CredentialsPath": "",
      "PullTimeoutSeconds": 30,
      "AckDeadlineSeconds": 60
    },
    "EncryptionKey": ""
  }
}